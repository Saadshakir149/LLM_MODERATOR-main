# ============================================================
# Supabase Configuration
# ============================================================
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ============================================================
# OpenAI Configuration
# ============================================================
OPENAI_API_KEY=sk-your-api-key-here
LLM_PROVIDER=deepseek
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=2000
# ============================================================
# Server Configuration
# ============================================================
# Production (Vercel)
FRONTEND_URL=https://llm-moderator-39gf.vercel.app
# Local React dev
# FRONTEND_URL=http://localhost:3000

# ============================================================
# Moderator Settings
# ============================================================
WELCOME_MESSAGE=Welcome everyone! I'm the Moderator.

# Story progression (number of sentences per chunk)
ACTIVE_STORY_STEP=1
PASSIVE_STORY_STEP=1

# Timing settings (in seconds)
PASSIVE_SILENCE_SECONDS=10
ACTIVE_SILENCE_SECONDS=20
STORY_CHUNK_INTERVAL=10

# Intervention windows (in seconds)
ACTIVE_INTERVENTION_WINDOW_SECONDS=20
PASSIVE_INTERVENTION_WINDOW_SECONDS=10

# Ending messages
ACTIVE_ENDING_MESSAGE=✨ We have reached the end of the story.

# ============================================================
# Uplift TTS — Pakistani Roman Urdu voice
# ============================================================
# Roman Urdu (roman_urdu/urdu/mixed) is synthesized by Uplift, not OpenAI, so it sounds
# Pakistani rather than Hindi/English-accented. Set a *Pakistani* Urdu voice id here — a
# wrong/Indian voice id is the usual cause of a Hindi-sounding moderator.
UPLIFTAI_API_KEY=your-uplift-api-key-here
UPLIFT_ROMAN_URDU_VOICE_ID=your-pakistani-urdu-voice-id   # (UPLIFT_VOICE_ID_URDU still works too)
UPLIFT_VOICE_ID_EN=your-english-voice-id                  # optional; English normally uses OpenAI
UPLIFT_OUTPUT_FORMAT=MP3_22050_128
# Fail-fast window: if Uplift doesn't respond within this many seconds it falls back
# (unless FORCE_UPLIFT_FOR_URDU=true). Healthy synthesis is ~1-3s.
UPLIFT_TIMEOUT=8.0
# true → Roman Urdu MUST use Uplift; on Uplift failure the clip is skipped rather than
# voiced by OpenAI's (Hindi-accented) English voice. false (default) → resilient fallback.
FORCE_UPLIFT_FOR_URDU=false
# true (default) → transliterate Roman Urdu to URDU SCRIPT before sending to Uplift, for
# native pronunciation. Chat + the messages table stay Roman Urdu (research data) — only the
# spoken audio uses Urdu script. Set false to send Roman Urdu to Uplift (more accented).
URDU_SCRIPT_TTS=true
