# Production: your Render (or other) Socket.IO / HTTP API origin — no trailing slash
REACT_APP_API_URL=https://your-backend.onrender.com

# Local backend
# REACT_APP_API_URL=http://localhost:5000

# Must match server ADMIN_TOKEN (sent as X-Admin-Token header)
REACT_APP_ADMIN_TOKEN=your-admin-token-here
